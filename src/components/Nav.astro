---
const { pathname } = Astro.url;
---
<nav>
  <div class="container nav-inner">
    <a href="/" class="nav-name">Your Name</a>
    <ul class="nav-links">
      <li><a href="/#work" class:list={['nav-link', { active: pathname.startsWith('/work') }]}>Work</a></li>
      <li><a href="/about" class:list={['nav-link', { active: pathname === '/about' }]}>About</a></li>
    </ul>
  </div>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    z-index: 10;
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }
  .nav-name {
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: -0.01em;
  }
  .nav-links {
    display: flex;
    gap: var(--space-md);
    list-style: none;
  }
  .nav-link {
    font-size: 0.9375rem;
    text-decoration: none;
    color: var(--color-muted);
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--color-text);
    opacity: 1;
  }
</style>
