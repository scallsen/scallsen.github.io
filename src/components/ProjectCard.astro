---
interface Props {
  title: string;
  company: string;
  year: string;
  description: string;
  slug?: string;
  external?: string;
  availableOnRequest?: boolean;
  thumbnail?: string;
}
const { title, company, year, description, slug, external, availableOnRequest, thumbnail } = Astro.props;
const href = external ?? `/work/${slug}`;
const isExternal = !!external;

const logoMap: Record<string, string> = {
  'Shopify': '/logos/shopify.svg',
};
const logoSrc = logoMap[company] ?? null;
---
{availableOnRequest ? (
  <div class="card card--no-link">
    {thumbnail && (
      <div class="card-thumbnail">
        <img src={thumbnail} alt={title} class="card-thumbnail-img" />
      </div>
    )}
    <div class="card-body">
      <div class="card-meta">
        {logoSrc && <img src={logoSrc} alt={company} class="card-logo" />}
        <span class="card-company">{company}</span>
        <span class="card-year">{year}</span>
      </div>
      <h3 class="card-title">{title}</h3>
      <p class="card-desc">{description}</p>
      <span class="card-cta">Available on request</span>
    </div>
  </div>
) : (
  <a href={href} class="card" target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener noreferrer' : undefined}>
    {thumbnail && (
      <div class="card-thumbnail">
        <img src={thumbnail} alt={title} class="card-thumbnail-img" />
      </div>
    )}
    <div class="card-body">
      <div class="card-meta">
        {logoSrc && <img src={logoSrc} alt={company} class="card-logo" />}
        <span class="card-company">{company}</span>
        <span class="card-year">{year}</span>
      </div>
      <h3 class="card-title">{title}</h3>
      <p class="card-desc">{description}</p>
      <span class="card-cta">{isExternal ? 'Visit →' : 'View case study →'}</span>
    </div>
  </a>
)}

<style>
  .card {
    display: block;
    padding: 0;
    border-top: 1px solid var(--color-border);
    text-decoration: none;
  }
  .card-thumbnail {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }
  .card-thumbnail-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }
  .card-body {
    padding: var(--space-md) 0;
  }
  .card:last-child {
    border-bottom: 1px solid var(--color-border);
  }
  a.card:hover .card-cta {
    opacity: 1;
  }
  .card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: 0.8125rem;
    color: var(--color-muted);
    margin-bottom: var(--space-xs);
  }
  .card-logo {
    width: 22px;
    height: 22px;
    display: block;
    flex-shrink: 0;
    margin-right: 4px;
  }
  .card-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: var(--space-xs);
    color: var(--color-text);
  }
  .card-desc {
    font-size: 0.9375rem;
    color: var(--color-muted);
    margin-bottom: var(--space-sm);
    max-width: 560px;
  }
  .card-cta {
    font-size: 0.875rem;
    color: var(--color-muted);
    opacity: 0.5;
    transition: opacity 0.15s;
  }
</style>
