---
interface Props {
  title: string;
  company: string;
  year: string;
  description: string;
  slug?: string;
  external?: string;
}
const { title, company, year, description, slug, external } = Astro.props;
const href = external ?? `/work/${slug}`;
const isExternal = !!external;
---
<a href={href} class="card" target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener noreferrer' : undefined}>
  <div class="card-meta">
    <span class="card-company">{company}</span>
    <span class="card-year">{year}</span>
  </div>
  <h3 class="card-title">{title}</h3>
  <p class="card-desc">{description}</p>
  <span class="card-cta">{isExternal ? 'Visit →' : 'View case study →'}</span>
</a>

<style>
  .card {
    display: block;
    padding: var(--space-md) 0;
    border-top: 1px solid var(--color-border);
    text-decoration: none;
  }
  .card:last-child {
    border-bottom: 1px solid var(--color-border);
  }
  .card:hover .card-cta {
    opacity: 1;
  }
  .card-meta {
    display: flex;
    gap: var(--space-sm);
    font-size: 0.8125rem;
    color: var(--color-muted);
    margin-bottom: var(--space-xs);
  }
  .card-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: var(--space-xs);
    color: var(--color-text);
  }
  .card-desc {
    font-size: 0.9375rem;
    color: var(--color-muted);
    margin-bottom: var(--space-sm);
    max-width: 560px;
  }
  .card-cta {
    font-size: 0.875rem;
    color: var(--color-muted);
    opacity: 0.5;
    transition: opacity 0.15s;
  }
</style>
