---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import commitCache from '../data/commit-cache.json';

async function getLastCommitDate(repo: string): Promise<Date | null> {
  try {
    const res = await fetch(`https://api.github.com/repos/${repo}/commits?per_page=1`, {
      headers: { 'Accept': 'application/vnd.github+json' },
    });
    if (!res.ok) return null;
    const [commit] = await res.json();
    const date = commit?.commit?.committer?.date;
    return date ? new Date(date) : null;
  } catch {
    return null;
  }
}

function relativeTime(date: Date): string {
  const diffDays = Math.floor((Date.now() - date.getTime()) / 86400000);
  if (diffDays === 0) return 'updated today';
  if (diffDays === 1) return 'updated yesterday';
  if (diffDays < 7) return `updated ${diffDays} days ago`;
  const weeks = Math.floor(diffDays / 7);
  if (weeks < 5) return `updated ${weeks} week${weeks > 1 ? 's' : ''} ago`;
  const months = Math.floor(diffDays / 30);
  if (months < 12) return `updated ${months} month${months > 1 ? 's' : ''} ago`;
  const years = Math.floor(diffDays / 365);
  return `updated ${years} year${years > 1 ? 's' : ''} ago`;
}

const allProjects = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
const caseStudies = allProjects.filter((p) => p.data.category === 'case-study');
const personalProjects = allProjects.filter((p) => p.data.category === 'personal' && !p.data.spotlight);

const spotlightProjects = await Promise.all(
  allProjects
    .filter((p) => p.data.spotlight)
    .map(async (p) => {
      const lastCommit = p.data.github ? await getLastCommitDate(p.data.github) : null;
      const cachedDate = p.data.github ? (commitCache as Record<string, string>)[p.data.github] : null;
      const resolvedDate = lastCommit ?? (cachedDate ? new Date(cachedDate) : null);
      const hasScreenshot = existsSync(join(process.cwd(), 'public', 'screenshots', `${p.slug}.png`));
      return { project: p, freshness: resolvedDate ? relativeTime(resolvedDate) : null, hasScreenshot };
    })
);
---
<Base title="Simon Callsen — Senior UX Designer">
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Simon Callsen",
      "jobTitle": "Senior UX Designer",
      "url": "https://scallsen.ca",
      "sameAs": [
        "https://www.linkedin.com/in/scallsen/",
        "https://github.com/scallsen"
      ]
    }
  </script>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="row">
        <div class="row-label hero-label">
          <img src="/pfp.png" alt="Simon Callsen" class="pfp" />
        </div>
        <div class="row-content hero-content">
          <h1>Simon Callsen</h1>
          <p class="hero-title">Senior UX Designer</p>
        </div>
      </div>
      <p class="hero-statement">7 years at Shopify – now building my own tools in Tokyo.</p>
      <div class="hero-links">
        <a href="https://www.linkedin.com/in/scallsen/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="https://github.com/scallsen" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="mailto:simon.callsen@gmail.com">Email</a>
      </div>
    </div>
  </section>

  <!-- Currently Building -->
  {spotlightProjects.length > 0 && (
    <section class="spotlight">
      <div class="container">
        <div class="row">
          <div class="row-label">
            <span class="section-label">Currently Building</span>
          </div>
          <div class="row-content spotlight-grid">
            {spotlightProjects.map(({ project: p, freshness, hasScreenshot }) => {
              const href = p.data.external ?? `/work/${p.slug}`;
              const isExternal = !!p.data.external;
              return (
                <a href={href} class="spotlight-card" target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener noreferrer' : undefined}>
                  {hasScreenshot && (
                    <div class="spotlight-preview">
                      <img src={`/screenshots/${p.slug}.png`} alt={p.data.title} class="spotlight-img" />
                    </div>
                  )}
                  <div class="spotlight-body">
                    <h3 class="spotlight-title">{p.data.title}</h3>
                    {freshness && <span class="spotlight-freshness">{freshness}</span>}
                    <p class="spotlight-desc">{p.data.description}</p>
                    <span class="spotlight-cta">{isExternal ? 'Visit →' : 'View →'}</span>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Case Studies -->
  <section class="work" id="work">
    <div class="container">
      <div class="row">
        <div class="row-label">
          <span class="section-label">Case Studies</span>
        </div>
        <div class="row-content">
          {caseStudies.map((p) => (
            <ProjectCard
              title={p.data.title}
              company={p.data.company}
              year={p.data.year}
              description={p.data.description}
              slug={p.slug}
              external={p.data.external}
              availableOnRequest={p.data.availableOnRequest}
              thumbnail={p.data.thumbnail}
            />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Personal Projects -->
  {personalProjects.length > 0 && (
    <section class="personal">
      <div class="container">
        <div class="row">
          <div class="row-label">
            <span class="section-label">Personal</span>
          </div>
          <div class="row-content">
            {personalProjects.map((p) => (
              <ProjectCard
                title={p.data.title}
                company={p.data.company}
                year={p.data.year}
                description={p.data.description}
                slug={p.slug}
                external={p.data.external}
              />
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- About -->
  <section class="about-blurb" id="about">
    <div class="container">
      <div class="row">
        <div class="row-label">
          <span class="section-label">About</span>
        </div>
        <div class="row-content">
          <p>
            I spent seven years at Shopify designing shipping and fulfillment software, starting as an intern and
            leaving as a senior designer.
          </p>
          <p>
            I enjoyed working on larger problems that spanned multiple teams—taking them from initial pitch through
            to execution.
          </p>
          <p>
            I'm currently based in Tokyo, going to Japanese language school, and building my own tools on the side.
            I'm looking for a product design role at an English-friendly company in Japan.
          </p>
          <p class="contact-line">
            <a href="mailto:simon.callsen@gmail.com">simon.callsen@gmail.com</a>
          </p>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ── Hero ── */
  .hero {
    padding-top: var(--space-md);
    padding-bottom: var(--space-lg);
  }
  .hero .row {
    column-gap: var(--space-md);
    align-items: center;
    margin-bottom: 0;
  }
  .hero-label {
    padding: 0;
  }
  .pfp {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    object-fit: cover;
    display: block;
  }
  .hero .row-content {
    border-left: none;
    padding-left: 0;
    padding-block: 0;
  }
  .hero h1 { margin-bottom: var(--space-xs); }
  .hero-title {
    font-size: 1.25rem;
    color: var(--color-muted);
    margin-bottom: 0;
  }
  .hero-statement {
    font-size: 1.125rem;
    color: var(--color-muted);
    line-height: 1.65;
    padding-left: calc(160px + var(--space-md));
  }
  .hero-links {
    display: flex;
    gap: var(--space-md);
    padding-left: calc(160px + var(--space-md));
    margin-top: var(--space-sm);
  }
  .hero-links a {
    font-size: 0.9375rem;
    color: var(--color-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1px;
  }
  .hero-links a:hover {
    color: var(--color-text);
    border-bottom-color: var(--color-text);
  }

  /* ── Full-width section borders ── */
  .spotlight,
  .work,
  .personal,
  .about-blurb {
    border-top: 1px solid var(--color-border);
  }

  /* Offset anchor scroll for sticky nav */
  .work,
  .about-blurb {
    scroll-margin-top: 56px;
  }

  /* ── Two-column grid row ── */
  .row {
    display: grid;
    grid-template-columns: 160px 1fr;
  }

  .row-label {
    padding: var(--space-md) var(--space-md) var(--space-md) 0;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
  }

  .row-content {
    border-left: 1px solid var(--color-border);
    padding-left: var(--space-md);
    padding-block: var(--space-md);
  }

  /* Card lists: borders extend to the column divider; cards carry their own left padding */
  .work .row-content,
  .personal .row-content {
    padding-left: 0;
    padding-block: 0;
    border-right: 1px solid var(--color-border);
  }
  .work .row-content :global(.card-body),
  .personal .row-content :global(.card-body) {
    padding-left: var(--space-md);
    padding-right: var(--space-md);
  }
  .work .row-content :global(.card:first-child),
  .personal .row-content :global(.card:first-child) {
    border-top: none;
  }
  .work .row-content :global(.card:last-child),
  .personal .row-content :global(.card:last-child) {
    border-bottom: none;
  }

  /* ── Currently Building: sub-grid in content column ── */
  .spotlight-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding: 0;
    border-right: 1px solid var(--color-border);
  }

  .spotlight-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
  }
  .spotlight-card + .spotlight-card {
    border-left: 1px solid var(--color-border);
  }
  .spotlight-card:hover .spotlight-cta { opacity: 1; }

  .spotlight-preview {
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
    aspect-ratio: 4 / 3;
  }
  .spotlight-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .spotlight-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: var(--space-md);
  }

  .spotlight-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }
  .spotlight-freshness {
    display: block;
    font-size: 0.75rem;
    color: var(--color-muted);
    margin-bottom: var(--space-sm);
  }
  .spotlight-desc {
    font-size: 0.9375rem;
    color: var(--color-muted);
    margin-bottom: var(--space-sm);
    line-height: 1.55;
  }
  .spotlight-cta {
    font-size: 0.875rem;
    color: var(--color-muted);
    opacity: 0.5;
    margin-top: auto;
  }

  /* ── About ── */
  .about-blurb .row-content p {
    max-width: 460px;
    line-height: 1.75;
    margin-bottom: var(--space-sm);
  }
  .contact-line a {
    color: var(--color-text);
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    /* Section label: larger, no allcaps, black */
    .section-label {
      font-size: 1.125rem;
      text-transform: none;
      letter-spacing: 0;
      color: var(--color-text);
    }

    /* Collapse two-column rows to single column */
    .row {
      grid-template-columns: 1fr;
    }
    .row-label {
      padding: var(--space-md) 0 var(--space-sm) 0;
    }
    .row-content {
      border-left: none;
      padding-left: 0;
      padding-top: 0;
    }
    .work .row-content,
    .personal .row-content {
      border-right: none;
    }

    /* Tighter vertical padding on hero and spotlight */
    .hero {
      padding-bottom: var(--space-md);
    }
    .spotlight-body {
      padding-top: var(--space-sm);
      padding-bottom: var(--space-md);
    }

    /* Hero: vertical stack — pfp → name/title → statement */
    .hero-label {
      padding-top: 0;
      padding-bottom: var(--space-sm);
    }
    .pfp {
      width: 80px;
    }
    .hero-statement {
      padding-left: 0;
    }
    .hero-links {
      padding-left: 0;
    }

    /* Stack spotlight cards vertically */
    .spotlight-grid {
      grid-template-columns: 1fr;
      border-right: none;
    }
    .spotlight-card + .spotlight-card {
      border-left: none;
      border-top: 1px solid var(--color-border);
    }

    /* Align card/spotlight text with images — let container padding do the work */
    .work .row-content :global(.card-body),
    .personal .row-content :global(.card-body) {
      padding-left: 0;
      padding-right: 0;
    }
    /* Tighten gap between thumbnail and card text */
    .work .row-content :global(.card-thumbnail + .card-body),
    .personal .row-content :global(.card-thumbnail + .card-body) {
      padding-top: var(--space-sm);
    }
    .spotlight-body {
      padding-left: 0;
      padding-right: 0;
    }
  }
</style>
