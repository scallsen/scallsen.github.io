---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
async function getLastCommitDate(repo: string): Promise<Date | null> {
  try {
    const res = await fetch(`https://api.github.com/repos/${repo}/commits?per_page=1`, {
      headers: { 'Accept': 'application/vnd.github+json' },
    });
    if (!res.ok) return null;
    const [commit] = await res.json();
    const date = commit?.commit?.committer?.date;
    return date ? new Date(date) : null;
  } catch {
    return null;
  }
}

function relativeTime(date: Date): string {
  const diffDays = Math.floor((Date.now() - date.getTime()) / 86400000);
  if (diffDays === 0) return 'updated today';
  if (diffDays === 1) return 'updated yesterday';
  if (diffDays < 7) return `updated ${diffDays} days ago`;
  const weeks = Math.floor(diffDays / 7);
  if (weeks < 5) return `updated ${weeks} week${weeks > 1 ? 's' : ''} ago`;
  const months = Math.floor(diffDays / 30);
  if (months < 12) return `updated ${months} month${months > 1 ? 's' : ''} ago`;
  const years = Math.floor(diffDays / 365);
  return `updated ${years} year${years > 1 ? 's' : ''} ago`;
}

const allProjects = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
const caseStudies = allProjects.filter((p) => p.data.category === 'case-study');
const personalProjects = allProjects.filter((p) => p.data.category === 'personal' && !p.data.spotlight);

const spotlightProjects = await Promise.all(
  allProjects
    .filter((p) => p.data.spotlight)
    .map(async (p) => {
      const lastCommit = p.data.github ? await getLastCommitDate(p.data.github) : null;
      return { project: p, freshness: lastCommit ? relativeTime(lastCommit) : null };
    })
);
---
<Base title="Your Name — Senior UX Designer">
  <!-- Hero -->
  <section class="hero container">
    <h1>Your Name</h1>
    <p class="hero-title">Senior UX Designer</p>
    <p class="hero-statement">I design commerce experiences that help merchants grow and customers feel understood.</p>
  </section>

  <!-- Currently Building -->
  {spotlightProjects.length > 0 && (
    <section class="spotlight container">
      <h2 class="section-label">Currently Building</h2>
      {spotlightProjects.map(({ project: p, freshness }) => {
        const href = p.data.external ?? `/work/${p.slug}`;
        const isExternal = !!p.data.external;
        return (
          <a href={href} class="spotlight-card" target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener noreferrer' : undefined}>
            <div class="spotlight-header">
              <h3 class="spotlight-title">{p.data.title}</h3>
              {freshness && <span class="spotlight-freshness">{freshness}</span>}
            </div>
            <p class="spotlight-desc">{p.data.description}</p>
            <span class="spotlight-cta">{isExternal ? 'Visit →' : 'View →'}</span>
          </a>
        );
      })}
    </section>
  )}

  <!-- Work -->
  <section class="work container" id="work">
    <h2 class="section-label">Case Studies</h2>
    {caseStudies.map((p) => (
      <ProjectCard
        title={p.data.title}
        company={p.data.company}
        year={p.data.year}
        description={p.data.description}
        slug={p.slug}
        external={p.data.external}
      />
    ))}
  </section>

  <!-- Personal Projects -->
  {personalProjects.length > 0 && (
    <section class="personal container">
      <h2 class="section-label">Personal</h2>
      {personalProjects.map((p) => (
        <ProjectCard
          title={p.data.title}
          company={p.data.company}
          year={p.data.year}
          description={p.data.description}
          slug={p.slug}
          external={p.data.external}
        />
      ))}
    </section>
  )}

  <!-- About blurb -->
  <section class="about-blurb container" id="about">
    <h2 class="section-label">About</h2>
    <p>
      I'm a product designer with seven years at Shopify, where I grew from intern to senior designer on the
      fulfillment and commerce infrastructure teams. I'm based in Tokyo and currently open to new opportunities.
    </p>
    <p class="contact-line">
      <a href="mailto:hello@yourname.com">hello@yourname.com</a>
    </p>
  </section>
</Base>

<style>
  .hero {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-xl);
  }
  .hero h1 {
    margin-bottom: var(--space-xs);
  }
  .hero-title {
    font-size: 1.25rem;
    color: var(--color-muted);
    margin-bottom: var(--space-md);
  }
  .hero-statement {
    font-size: 1.125rem;
    color: var(--color-muted);
    max-width: 480px;
    line-height: 1.65;
  }
  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-bottom: var(--space-md);
  }
  .spotlight {
    padding-bottom: var(--space-lg);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-lg);
  }
  .spotlight-card {
    display: block;
    padding: var(--space-md) 0;
    border-top: 1px solid var(--color-border);
    text-decoration: none;
  }
  .spotlight-card:last-child {
    border-bottom: 1px solid var(--color-border);
  }
  .spotlight-card:hover .spotlight-cta {
    opacity: 1;
  }
  .spotlight-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }
  .spotlight-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
  }
  .spotlight-freshness {
    font-size: 0.8125rem;
    color: var(--color-muted);
  }
  .spotlight-desc {
    font-size: 0.9375rem;
    color: var(--color-muted);
    margin-bottom: var(--space-sm);
    max-width: 560px;
  }
  .spotlight-cta {
    font-size: 0.875rem;
    color: var(--color-muted);
    opacity: 0.5;
  }
  .work {
    padding-bottom: var(--space-lg);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-lg);
  }
  .personal {
    padding-bottom: var(--space-xl);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-lg);
  }
  .about-blurb {
    padding-bottom: var(--space-xl);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-lg);
  }
  .about-blurb p {
    max-width: 520px;
    line-height: 1.75;
    margin-bottom: var(--space-sm);
  }
  .contact-line a {
    font-size: 1rem;
    color: var(--color-text);
  }
</style>
